# Supabase — copy to .env.local and fill in.
# Project ref + anon key: dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role: server-side only — used for admin actions (Phase 4)
# Never commit. Keep out of NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY=
